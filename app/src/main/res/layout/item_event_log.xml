<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:backgroundTint="@android:color/white"
    app:cardElevation="2dp"
    app:strokeColor="@color/event_tracker_accent"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/logDateTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/event_tracker_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/logDetailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ink_900" />

        <TextView
            android:id="@+id/logSeverityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ink_600" />

        <TextView
            android:id="@+id/logActionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ink_600" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
